# Netlify headers — cache + sécurité

# Assets statiques — cache 1 an (immutable car noms hashés par Vite)
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Images et fonts
/*.png
  Cache-Control: public, max-age=86400
/*.jpg
  Cache-Control: public, max-age=86400
/*.svg
  Cache-Control: public, max-age=86400
/*.woff2
  Cache-Control: public, max-age=31536000, immutable

# HTML — jamais caché (toujours la dernière version)
/*.html
  Cache-Control: no-cache, no-store, must-revalidate

# JSON traductions — revalidation douce
/locales/*
  Cache-Control: public, max-age=3600, stale-while-revalidate=86400

# Sitemap et robots — cache 24h
/sitemap.xml
  Cache-Control: public, max-age=86400
/robots.txt
  Cache-Control: public, max-age=86400

# En-têtes de sécurité pour toutes les pages
/*
  X-Frame-Options: SAMEORIGIN
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=(self)
  X-XSS-Protection: 1; mode=block
